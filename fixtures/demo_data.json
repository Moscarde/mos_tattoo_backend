{
  "model": "dashboards.datasource",
  "pk": "dcd7cfd3-51e9-49d9-a9a9-d88f77357bf4",
  "fields": {
    "nome": "Taxa Cancelamento",
    "descricao": "",
    "connection": "02405011-9fa4-4dfe-ad98-792eb30e71ee",
    "sql": "SELECT \r\n    s.sold_at::date AS sold_at,\r\n    u.code AS unit_code,\r\n    u.name AS unit_name,\r\n    sel.name AS seller_name,\r\n    COUNT(*) AS total_vendas,\r\n    COUNT(CASE WHEN s.canceled = true THEN 1 END) AS total_canceladas,\r\n    ROUND(\r\n        (COUNT(CASE WHEN s.canceled = true THEN 1 END)::numeric / NULLIF(COUNT(*), 0)) * 100, \r\n        2\r\n    ) AS taxa_cancelamento_percentual\r\nFROM public.sales s\r\nJOIN public.units u ON s.unit_id = u.id\r\nJOIN public.sellers sel ON s.seller_id = sel.id\r\nGROUP BY 1, 2, 3, 4\r\nORDER BY 1 DESC, 2 ASC, 4 ASC",
    "columns_metadata": [
      {
